###############################################################################
# DCL LMS — Node backend REST Client request collection
#
# HOW TO USE
#   1. Install the VS Code extension "REST Client" (humao.rest-client).
#   2. Start the Node server:  npm run dev   (defaults to http://localhost:8000)
#   3. Click the "Send Request" codelens that appears above each ### request.
#
# Variables below can be edited once and are reused by every request.
# Requests are grouped by the router they are mounted on: /app, /auth, /hr, /hrms.
# HR-admin routes require a valid admin_card_no (an ULEVL user in SEC_USERNAME).
###############################################################################

@baseUrl = http://localhost:8000

# --- Common sample identifiers (edit to match your DB) -----------------------
@adminCard   = 100001.1
@empCard     = 100660.1
@empcode     = 100011
@phone       = 03363052865
@fromDate    = 2026-06-01
@toDate      = 2026-06-30
@date        = 2026-07-01
@rosterMonth = MAY-26


###############################################################################
# APP  (mounted at /app)  —  src/routes/appVersion.routes.js
###############################################################################

### App root (stub handler)
GET {{baseUrl}}/app


###############################################################################
# AUTH  (mounted at /auth)  —  src/routes/auth.routes.js
###############################################################################

### Login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "username": "3458000041",
  "password": "abcd1234"
}

### Profile by card_no
GET {{baseUrl}}/auth/profile/{{empCard}}

### Lookup employee by phone (no auth)
GET {{baseUrl}}/auth/lookup/{{phone}}

### Change password
POST {{baseUrl}}/auth/change-password/{{empCard}}
Content-Type: application/json

{
  "old_password": "abcd1234",
  "new_password": "newpass1"
}

### Employee self-service dashboard
GET {{baseUrl}}/auth/dashboard/{{empCard}}

# --- Attendance --------------------------------------------------------------

### Face attendance (smart check-in / check-out)
POST {{baseUrl}}/auth/attendance/face
Content-Type: application/json

{
  "card_no": "{{empCard}}",
  "attendance_type": "check_in",
  "latitude": 24.8607,
  "longitude": 67.0011
}

### Attendance summary (aggregated stats for a range)
GET {{baseUrl}}/auth/attendance/summary?emp_pk={{empCard}}&from_date={{fromDate}}&to_date={{toDate}}

### Attendance report — date range (one row per day)
GET {{baseUrl}}/auth/attendance/report-range/{{empCard}}?from_date=2026-01-01&to_date=2026-07-31

### Attendance report — single day
GET {{baseUrl}}/auth/attendance/report/{{empCard}}/2026-06-29

### Manual attendance (smart check-in / check-out)
POST {{baseUrl}}/auth/attendance/{{empCard}}
Content-Type: application/json

{
  "latitude": 24.8607,
  "longitude": 67.0011
}

# --- Leave -------------------------------------------------------------------

### Leave balances
GET {{baseUrl}}/auth/leave-balances/{{empCard}}

### Leave types (full LOV merged with balances)
GET {{baseUrl}}/auth/leave-types/{{empCard}}

### Leave status (application history)
GET {{baseUrl}}/auth/leave-status/{{empCard}}

### Apply leave
POST {{baseUrl}}/auth/apply-leave/{{empCard}}
Content-Type: application/json

{
  "leave_type_id": 1,
  "from_date": "2026-07-05",
  "to_date": "2026-07-06",
  "reason": "Personal",
  "half_day": false
}

# --- Location (HR-admin for report/summary/history) --------------------------

### Location batch upload (employee)
POST {{baseUrl}}/auth/location/batch
Content-Type: application/json

{
  "card_no": "100002.1",
  "locations": [
    { "latitude": 24.8607, "longitude": 67.0011, "accuracy": 10.0, "recorded_at": "2026-07-01T09:00:00Z" },
    { "latitude": 24.8615, "longitude": 67.0025, "accuracy": 8.5,  "recorded_at": "2026-07-01T09:05:00Z" }
  ]
}

### Location report — summary (HR-admin)
GET {{baseUrl}}/auth/location/report/summary?from_date=2026-07-01&to_date=2026-07-31&admin_card_no={{adminCard}}

### Location report — trail (HR-admin)
GET {{baseUrl}}/auth/location/report/trail?from_date=2026-07-01&to_date=2026-07-31&admin_card_no={{adminCard}}

### Location summary for a day (HR-admin)
GET {{baseUrl}}/auth/location/summary?date={{date}}&admin_card_no={{adminCard}}

### Location history for one employee (HR-admin)
GET {{baseUrl}}/auth/location/history/100002.1?date={{date}}&admin_card_no={{adminCard}}


###############################################################################
# HR  (mounted at /hr)  —  src/routes/hr.routes.js   [HR-admin]
###############################################################################

### HR employee search (whole EMPLOYEE view, NOT company/branch scoped)
GET {{baseUrl}}/hr/employees/search?q=Saad&admin_card_no={{adminCard}}

### HR face enrollment (requires >= 10 frames; base64 JPEGs in real use)
POST {{baseUrl}}/hr/face/enroll?admin_card_no={{adminCard}}
Content-Type: application/json

{
  "card_no": "{{empCard}}",
  "frames": ["f1","f2","f3","f4","f5","f6","f7","f8","f9","f10"]
}


###############################################################################
# HRMS  (mounted at /hrms)  —  src/routes/hrms.routes.js   [HR-admin]
###############################################################################

# --- Dashboard ---------------------------------------------------------------

### HRMS dashboard analytics
GET {{baseUrl}}/hrms/dashboard/analytics?admin_card_no={{adminCard}}&date={{date}}

### HRMS dashboard
GET {{baseUrl}}/hrms/dashboard?admin_card_no={{adminCard}}&date={{date}}

# --- Attendance reports ------------------------------------------------------

### Bulk attendance summary (per-employee)
GET {{baseUrl}}/hrms/attendance/bulk?admin_card_no={{adminCard}}&from_date={{fromDate}}&to_date={{toDate}}

### Attendance details
GET {{baseUrl}}/hrms/attendance/details?admin_card_no={{adminCard}}&from_date={{fromDate}}&to_date={{toDate}}

# --- Employees ---------------------------------------------------------------

### Search employees (company/branch scoped)
GET {{baseUrl}}/hrms/employees/search?q=ali&admin_card_no={{adminCard}}

### Employee ID card (resolved names for printing)
GET {{baseUrl}}/hrms/employees/{{adminCard}}/card?admin_card_no={{adminCard}}

### Get one employee (extended)
GET {{baseUrl}}/hrms/employees/{{empCard}}?admin_card_no={{adminCard}}

### Update employee
PUT {{baseUrl}}/hrms/employees/{{empcode}}?admin_card_no={{adminCard}}
Content-Type: application/json

{
  "mobile": "03001234567",
  "email": "a@b.com"
}

### List employees (status: A active, I inactive, L left)
GET {{baseUrl}}/hrms/employees?admin_card_no={{adminCard}}&status=A

### Register employee
POST {{baseUrl}}/hrms/employees?admin_card_no={{adminCard}}
Content-Type: application/json

{
  "name": "Test Employee",
  "unit_id": 1,
  "status": "A",
  "mobile": "03001234567",
  "email": "test@dewan.com"
}

# --- Duty roster (read-only, ERP-owned) --------------------------------------

### Employee duty roster for a month
GET {{baseUrl}}/hrms/duty-roster/100108.1?admin_card_no={{adminCard}}&month={{rosterMonth}}
